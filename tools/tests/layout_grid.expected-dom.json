              "children": [
                {
                  "type": "text",
                  "data": "\n  body { margin: 8px; }\n  .grid-fr { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 10px; background: lightblue; margin-bottom: 10px; }\n  .grid-px { display: grid; grid-template-columns: 100px 200px 100px; gap: 5px; background: lightgreen; margin-bottom: 10px; }\n  .grid-pct { display: grid; grid-template-columns: 25% 50% 25%; gap: 5px; background: lightcoral; margin-bottom: 10px; }\n  .grid-repeat { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; background: lightyellow; margin-bottom: 10px; }\n  .grid-minmax { display: grid; grid-template-columns: minmax(100px, 1fr) minmax(50px, 200px) 1fr; gap: 10px; background: lightpink; margin-bottom: 10px; }\n  .grid-rows { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 100px 200px; gap: 10px; background: lightcyan; margin-bottom: 10px; }\n  .grid-areas { display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-areas: \"header header header\" \"sidebar content content\" \"footer footer footer\"; gap: 10px; background: lavender; margin-bottom: 10px; }\n  .grid-areas .header { grid-area: header; background: lightcoral; }\n  .grid-areas .sidebar { grid-area: sidebar; background: lightgreen; }\n  .grid-areas .content { grid-area: content; background: lightblue; }\n  .grid-areas .footer { grid-area: footer; background: lightyellow; }\n  .grid-span { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; background: mistyrose; margin-bottom: 10px; }\n  .grid-span .span2 { grid-column: span 2; background: lightcoral; }\n  .grid-span .span3 { grid-column: span 3; background: lightgreen; }\n  .grid-span .full { grid-column: 1 / -1; background: lightblue; }\n",
                  "data_normalized": "body { margin: 8px; } .grid-fr { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 10px; background: lightblue; margin-bottom: 10px; } .grid-px { display: grid; grid-template-columns: 100px 200px 100px; gap: 5px; background: lightgreen; margin-bottom: 10px; } .grid-pct { display: grid; grid-template-columns: 25% 50% 25%; gap: 5px; background: lightcoral; margin-bottom: 10px; } .grid-repeat { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; background: lightyellow; margin-bottom: 10px; } .grid-minmax { display: grid; grid-template-columns: minmax(100px, 1fr) minmax(50px, 200px) 1fr; gap: 10px; background: lightpink; margin-bottom: 10px; } .grid-rows { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 100px 200px; gap: 10px; background: lightcyan; margin-bottom: 10px; } .grid-areas { display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-areas: \"header header header\" \"sidebar content content\" \"footer footer footer\"; gap: 10px; background: lavender; margin-bottom: 10px; } .grid-areas .header { grid-area: header; background: lightcoral; } .grid-areas .sidebar { grid-area: sidebar; background: lightgreen; } .grid-areas .content { grid-area: content; background: lightblue; } .grid-areas .footer { grid-area: footer; background: lightyellow; } .grid-span { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; background: mistyrose; margin-bottom: 10px; } .grid-span .span2 { grid-column: span 2; background: lightcoral; } .grid-span .span3 { grid-column: span 3; background: lightgreen; } .grid-span .full { grid-column: 1 / -1; background: lightblue; }"
