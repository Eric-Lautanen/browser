                {
                  "type": "text",
                  "data": "\n  body { margin: 8px; }\n  .flex-row { display: flex; flex-direction: row; gap: 10px; background: lightblue; margin-bottom: 10px; }\n  .flex-column { display: flex; flex-direction: column; gap: 5px; background: lightgreen; height: 200px; margin-bottom: 10px; }\n  .flex-wrap { display: flex; flex-wrap: wrap; width: 250px; gap: 10px; background: lightcoral; margin-bottom: 10px; }\n  .flex-wrap .item { width: 80px; height: 50px; background: lightyellow; }\n  .justify-start { display: flex; justify-content: flex-start; background: lightsalmon; margin-bottom: 10px; }\n  .justify-center { display: flex; justify-content: center; background: lightpink; margin-bottom: 10px; }\n  .justify-end { display: flex; justify-content: flex-end; background: lightcyan; margin-bottom: 10px; }\n  .justify-between { display: flex; justify-content: space-between; background: lavender; margin-bottom: 10px; }\n  .justify-around { display: flex; justify-content: space-around; background: mistyrose; margin-bottom: 10px; }\n  .justify-evenly { display: flex; justify-content: space-evenly; background: honeydew; margin-bottom: 10px; }\n  .align-start { display: flex; align-items: flex-start; height: 80px; background: lightblue; margin-bottom: 10px; }\n  .align-center { display: flex; align-items: center; height: 80px; background: lightgreen; margin-bottom: 10px; }\n  .align-end { display: flex; align-items: flex-end; height: 80px; background: lightcoral; margin-bottom: 10px; }\n  .align-stretch { display: flex; align-items: stretch; height: 80px; background: lightyellow; margin-bottom: 10px; }\n  .align-self { display: flex; align-items: flex-start; height: 80px; background: lightpink; margin-bottom: 10px; }\n  .align-self .self-center { align-self: center; }\n  .align-self .self-end { align-self: flex-end; }\n  .align-content { display: flex; flex-wrap: wrap; align-content: center; height: 150px; width: 200px; background: lavender; margin-bottom: 10px; }\n  .align-content .item { width: 50px; height: 30px; background: lightcoral; margin: 5px; }\n  .flex-grow { display: flex; width: 400px; background: lightblue; margin-bottom: 10px; }\n  .flex-grow .grow1 { flex-grow: 1; background: lightcoral; }\n  .flex-grow .grow2 { flex-grow: 2; background: lightgreen; }\n  .flex-grow .nogrow { flex-grow: 0; background: lightyellow; }\n  .flex-shrink { display: flex; width: 200px; background: lightpink; margin-bottom: 10px; }\n  .flex-shrink .shrink-item { flex-basis: 100px; flex-shrink: 1; background: lightcyan; }\n  .flex-shrink .noshrink { flex-basis: 100px; flex-shrink: 0; background: lavender; }\n  .flex-basis { display: flex; width: 400px; background: mistyrose; margin-bottom: 10px; }\n  .flex-basis .basis-item { flex-basis: 100px; background: lightblue; }\n  .order { display: flex; background: honeydew; margin-bottom: 10px; }\n  .order .item1 { order: 2; background: lightcoral; }\n  .order .item2 { order: 1; background: lightgreen; }\n  .order .item3 { order: 3; background: lightyellow; }\n",
